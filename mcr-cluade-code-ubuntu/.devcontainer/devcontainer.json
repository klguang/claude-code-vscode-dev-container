{
  "name": "Claude Code 无值守环境",
  "build": { "dockerfile": "Dockerfile" },
  // 直接加载项目根目录的.env作为环境变量，密钥无需硬编码
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],
  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code"]
    }
  },
  "remoteUser": "vscode",
  "waitFor": "postStartCommand",
  "postCreateCommand": "bash .devcontainer/setup-proxy.sh && bash .devcontainer/setup-claude.sh \"${containerWorkspaceFolder}\"",
  "postStartCommand": "bash .devcontainer/setup-claude.sh \"${containerWorkspaceFolder}\""
}
